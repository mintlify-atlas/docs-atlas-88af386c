  "keyFeatures": [
    "TikTok-style vertical video browsing with swipe navigation",
    "Multi-server support (Emby, Plex, local folders, LAN file server)",
    "Cross-platform apps (Web, Android, iOS/iPadOS, Apple Watch)",
    "Media library management with favorites and collections",
    "LAN folder server mode for local network streaming",
    "Responsive design with grid and feed view modes",
    "Orientation filtering and automatic layout optimization",
    "PWA support with offline capabilities"
  ],
  "publicApiSurface": [
    "MediaClient - Abstract base class for media server clients",
    "EmbyClient - Emby server integration",
    "PlexClient - Plex server integration", 
    "FolderServerClient - LAN folder server client",
    "LocalClient - Local file system client",
    "ClientFactory - Factory for creating client instances",
    "ServerConfig - Server configuration interface",
    "EmbyItem - Media item data structure",
    "EmbyLibrary - Media library structure",
    "VideoResponse - Paginated video response",
    "FeedType - Content feed type ('latest', 'random', 'favorites')",
    "OrientationMode - Video orientation filter ('vertical', 'horizontal', 'both')"
  ]
